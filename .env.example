# Backend — copy to backend/.env and fill in your key

# Hugging Face (recommended) — get a token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here
HF_MODEL=Qwen/Qwen2.5-7B-Instruct
# LLM_PROVIDER=huggingface

# Google Gemini (optional alternative)
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# auto = Hugging Face if HF_TOKEN is set, else Gemini if GEMINI_API_KEY is set
LLM_PROVIDER=auto

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend (optional)
# VITE_API_URL=/api
# VITE_WS_URL=http://localhost:8000
